  "settings": {
    "prompt_timeout_seconds": 60,
    "auto_deny_on_timeout": true,
    "show_command_analysis": true,
    "show_impact_preview": true,
    "chain_aware_prompting": true,
    "log_approvals": true,
    "log_file": "~/.claude/hook-approvals.log"
  },
  "command_inspectors": {
    "curl_needs_data_check": [
      "-d", "--data", "--data-ascii", "--data-binary", "--data-raw", "--data-urlencode"
    ],
    "wget_needs_download_check": [
      "--post-data", "--post-file", "--method=POST"
    ]
  }
