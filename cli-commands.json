{
  "_comment": "CLI Command Patterns for Pre-Tool-Use Hook - Used by pre-cli-hook.ps1 and pre-cli-hook-copilot.ps1",
  "version": "2.8.0",
  "_note": "v2.8.0: Fixed Test-IsPowerShellModifying to handle piped commands (|). Each pipe segment checked independently for modifying verbs.",

  "trusted_script_files": [
    "test-runner-copilot.ps1"
  ],

  "script_patterns": [
    "^\\.\\/[^\\s]+\\.sh$",
    "^\\.\\/[^\\s]+$",
    "^bash\\s+[^\\s]+\\.sh$",
    "^sh\\s+[^\\s]+\\.sh$",
    "^sh\\s+[^\\s]+$",
    "^python\\d?\\s+[^\\s]+$",
    "^python\\d?\\.\\d?\\s+[^\\s]+$",
    "^perl\\s+[^\\s]+$",
    "^node\\s+[^\\s]+$",
    "^source\\s+[^\\s]+$",
    "^\\.\\s+[^\\s]+$",
    "^\\.\\/gradlew\\s+",
    "^\\.\\/mvnw\\s+",
    "^\\.\\/manage\\.py\\s+",
    "^ruby\\s+[^\\s]+$",
    "^php\\s+[^\\s]+$",
    "^go\\s+run\\s+[^\\s]+$",
    "^Rscript\\s+[^\\s]+$"
  ],

  "ssh_pattern": "^ssh\\s+",

  "aws_read_only_patterns": [
    "^aws\\s+\\S+\\s+(describe|list|get|show|head|lookup)-",
    "^aws\\s+s3\\s+ls",
    "^aws\\s+sts\\s+decode-authorization-message",
    "^aws\\s+logs\\s+filter-",
    "^aws\\s+iam\\s+simulate-",
    "^aws\\s+dynamodb\\s+scan",
    "^aws\\s+dynamodb\\s+query"
  ],

  "aws_modifying_patterns": [
    "^aws\\s+\\S+\\s+(create|delete|remove|terminate|stop|start|reboot|modify|update|put|upload|download|sync|rm|cp|mv|run|invoke|execute|attach|detach|associate|disassociate|enable|disable|add|register|deregister|tag|untag|reset|cancel|restore|import|export|publish|deploy|rollback|rotate|revoke|authorize|flush|purge|send|trigger|activate|deactivate|suspend|resume)-",
    "^aws\\s+s3\\s+(rm|cp|mv|sync)",
    "^aws\\s+lambda\\s+invoke",
    "^aws\\s+sns\\s+publish",
    "^aws\\s+sso\\s+login",
    "^aws\\s+dynamodb\\s+batch-write-"
  ],

