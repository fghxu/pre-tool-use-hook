{
  "_comment": "CLI Command Patterns for Pre-Tool-Use Hook - Used by pre-cli-hook.ps1",
  "_version": "1.1.0",

  "script_patterns": [
    "^\\.\\\/[^\\s]+\\.sh$",
    "^\\.\\\/[^\\s]+$",
    "^bash\\s+[^\\s]+\\.sh$",
    "^sh\\s+[^\\s]+\\.sh$",
    "^sh\\s+[^\\s]+$",
    "^python\\d?\\s+[^\\s]+$",
    "^python\\d?\\.\\d?\\s+[^\\s]+$",
    "^perl\\s+[^\\s]+$",
    "^node\\s+[^\\s]+$",
    "^source\\s+[^\\s]+$",
    "^\\.\\s+[^\\s]+$",
    "^\\.\\\/[^\\s]+",
    "^\\.\\\/gradlew\\s+",
    "^\\.\\\/mvnw\\s+"
  ],

  "ssh_pattern": "^ssh\\s+",

  "aws_read_only_patterns": [
    "^aws\\s+\\S+\\s+(describe|list|get|show|head)-",
    "^aws\\s+s3\\s+ls"
  ],

  "aws_modifying_patterns": [
    "^aws\\s+\\S+\\s+(create|delete|remove|terminate|stop|start|reboot|modify|update|put|upload|download|sync|rm)-",
    "^aws\\s+s3\\s+(rm|cp|mv|sync)",
    "^aws\\s+s3api\\s+(put|delete)-"
  ],

  "linux_read_only_commands": [
    "ls", "pwd", "cd", "echo", "cat", "head", "tail", "grep", "find", "which",
    "whoami", "id", "groups", "file", "ps", "df", "du", "free", "uname",
    "hostname", "date", "uptime", "who", "wc", "sort", "uniq", "less", "more"
  ],

  "linux_modifying_commands": [
    "rm", "rmdir", "mv", "cp", "scp", "rsync", "touch", "mkdir",
    "chmod", "chown", "chgrp", "setfacl", "useradd", "userdel",
    "usermod", "passwd", "groupadd", "groupdel", "mount", "umount",
    "fsck", "mkfs", "dd", "shutdown", "reboot", "halt", "poweroff",
    "yum", "apt-get", "dnf", "pip", "npm", "composer", "gem",
    "mysql", "psql", "redis-cli", "mongosh", "mongo", "systemctl"
  ],

  "powershell_read_only_verbs": [
    "Get-", "Test-", "Select-", "Where-", "Measure-", "Find-", "Write-"
  ],

  "powershell_modifying_verbs": [
    "Remove-", "Move-", "Copy-", "New-", "Set-", "Clear-", "Rename-", "Stop-", "Start-", "Restart-", "Invoke-"
  ],

  "docker_read_only_commands": [
    "ps", "images", "inspect", "logs", "stats", "info"
  ],

  "docker_modifying_commands": [
    "run", "exec", "rm", "rmi", "stop", "kill", "build", "push", "pull", "commit", "tag"
  ],

  "terraform_read_only_commands": [
    "show", "output", "plan", "validate", "fmt"
  ],

  "terraform_modifying_commands": [
    "apply", "destroy", "taint", "import", "refresh"
  ]
}
